# ══════════════════════════════════════════════════════════
# .gitignore for Money Manager
# Tells Git which files NOT to track / upload to GitHub.
# Rule: never commit things that are auto-generated,
#       contain secrets, or are too large / machine-specific.
# ══════════════════════════════════════════════════════════


# ── PYTHON ─────────────────────────────────────────────────
# Compiled bytecode — Python generates these automatically, never commit them
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments — each developer creates their own locally
venv/
.venv/
env/
.env/
ENV/

# Python egg / build artifacts
*.egg-info/
dist/
build/
.eggs/

# pytest cache
.pytest_cache/
.coverage
htmlcov/


# ── ENVIRONMENT / SECRETS ──────────────────────────────────
# NEVER commit .env files — they contain passwords, API keys, secret keys
.env
.env.local
.env.*.local
*.env
secrets.py


# ── DATABASE ───────────────────────────────────────────────
# The SQLite database file contains real user data — never commit it.
# Each developer / deployment creates their own fresh database.
data/money.db
data/*.db
*.db
*.sqlite
*.sqlite3


# ── UPLOADED FILES & CACHE ─────────────────────────────────
# Receipt images uploaded by users — too large for git, machine-specific
data/uploads/
# Auto-generated currency rate cache — refreshes automatically at runtime
data/currency_cache.json


# ── NODE / REACT / VITE ────────────────────────────────────
# node_modules is huge (can be 200MB+). Anyone can recreate it with: npm install
frontend/node_modules/
node_modules/

# Vite build output — generated by: npm run build
frontend/dist/
frontend/.vite/
dist/

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local npm config
.npmrc


# ── IDE / EDITOR FILES ─────────────────────────────────────
# VS Code workspace settings (keep .vscode/extensions.json if you want,
# but don't commit personal settings or launch configs)
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# JetBrains IDEs (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project


# ── WINDOWS SYSTEM FILES ───────────────────────────────────
# Windows creates these automatically in every folder — never useful in git
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Windows Zone Identifier (created when downloading files)
*.Identifier


# ── MACOS SYSTEM FILES (if collaborating with Mac users) ───
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ── LOGS ───────────────────────────────────────────────────
*.log
logs/
log/


# ── MISC ───────────────────────────────────────────────────
# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo

# OS-generated thumbnail cache
*.cache
